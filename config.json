{
  "profiles": {
    "production": {
      "listeners": [
        {
          "address": "0.0.0.0",
          "port": 8084,
          "https_enable": false
        }
      ],
      "app": {
        "number_of_threads": 8,
        "run_as_daemon": false
      },
      "static_files": {
        "root_path": "/home/avr/.local/html/TypeTrainer/product",
        "dirs": [
          {
            "uri": "/",
            "path": "."
          },
          {
            "uri": "/css",
            "path": "./css"
          },
          {
            "uri": "/js",
            "path": "./js"
          },
          {
            "uri": "/assets",
            "path": "./assets"
          }
        ]
      },
      "database": {
        "sqlite3": {
          "db_path": "${HOME}/.local/share/typetrainer/production/data/typetrainer.db"
        }
      },
      "log": {
        "log_path": "${HOME}/.local/share/typetrainer/production/logs",
        "logfile_base_name": "typetrainer",
        "logfile_max_size": 10485760,
        "log_level": "INFO"
      }
    },
    "test": {
      "listeners": [
        {
          "address": "0.0.0.0",
          "port": 9094,
          "https_enable": false
        }
      ],
      "app": {
        "number_of_threads": 2,
        "run_as_daemon": false
      },
      "static_files": {
        "root_path": "/home/avr/.local/html/TypeTrainer/test",
        "dirs": [
          {
            "uri": "/",
            "path": "."
          },
          {
            "uri": "/css",
            "path": "./css"
          },
          {
            "uri": "/js",
            "path": "./js"
          },
          {
            "uri": "/assets",
            "path": "./assets"
          }
        ]
      },
      "database": {
        "sqlite3": {
          "db_path": "${HOME}/.local/share/typetrainer/test/data/typetrainer.db"
        }
      },
      "log": {
        "log_path": "${HOME}/.local/share/typetrainer/test/logs",
        "logfile_base_name": "typetrainer-test",
        "logfile_max_size": 5242880,
        "log_level": "DEBUG"
      }
    }
  }
}
